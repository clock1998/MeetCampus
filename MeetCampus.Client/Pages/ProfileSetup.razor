@page "/profile/setup"
@attribute [Authorize]
@using MeetCampus.Shared.Models
@using MeetCampus.Shared.Services.Http
@using MeetCampus.Client.Resources
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@using System.Linq.Expressions
@inject MeetCampus.Shared.Services.Profile.IProfileSetupClient ProfileClient
@inject IStringLocalizer<ProfileResource> L
@implements IDisposable

<PageTitle>@L["ProfileSetup_PageTitle"]</PageTitle>

<div class="bg-base-100 px-6 py-12 lg:py-20">
    <div class="mx-auto max-w-4xl">
        <section class="card bg-base-200 border-base-300 rounded-3xl border p-6 shadow-sm lg:p-8">
            <div class="mb-6 space-y-2">
                <h1 class="text-base-content text-3xl font-bold">@L["ProfileSetup_Title"]</h1>
                <p class="text-base-content/70">@L["ProfileSetup_Description"]</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-error mb-4">@errorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success mb-4">@successMessage</div>
            }

            @if (isLoading)
            {
                <div class="text-base-content/70">@L["ProfileSetup_Loading"]</div>
            }
            else
            {
                <EditForm EditContext="editContext" OnValidSubmit="SaveAsync" class="space-y-5">
                    <DataAnnotationsValidator />
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">@L["Profile_Gender"]</legend>
                        <InputSelect @bind-Value="profile.GenderId" class="select select-bordered w-full">
                            <option value="">@L["ProfileSetup_SelectPlaceholder"]</option>
                            @foreach (var option in genders)
                            {
                                <option value="@option.Id">@GetDisplay(option)</option>
                            }
                        </InputSelect>
                    </fieldset>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">@L["Profile_Sexuality"]</legend>
                        <InputSelect @bind-Value="profile.SexualityId" class="select select-bordered w-full">
                            <option value="">@L["ProfileSetup_SelectPlaceholder"]</option>
                            @foreach (var option in sexualities)
                            {
                                <option value="@option.Id">@GetDisplay(option)</option>
                            }
                        </InputSelect>
                    </fieldset>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">@L["Profile_StudyDomain"]</legend>
                        <InputSelect @bind-Value="profile.StudyDomainId" class="@SelectClass(() => profile.StudyDomainId)">
                            <option value="">@L["ProfileSetup_SelectPlaceholder"]</option>
                            @foreach (var option in studyDomains)
                            {
                                <option value="@option.Id">@GetDisplay(option)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => profile.StudyDomainId" class="text-error text-sm mt-1" />
                    </fieldset>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">@L["Profile_School"]</legend>
                        <InputSelect @bind-Value="profile.SchoolId" class="@SelectClass(() => profile.SchoolId)">
                            <option value="">@L["ProfileSetup_SelectPlaceholder"]</option>
                            @foreach (var option in schools)
                            {
                                <option value="@option.Id">@GetDisplay(option)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => profile.SchoolId" class="text-error text-sm mt-1" />
                    </fieldset>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">@L["Profile_Language"]</legend>
                        <InputSelect @bind-Value="profile.LanguageId" class="@SelectClass(() => profile.LanguageId)">
                            <option value="">@L["ProfileSetup_SelectPlaceholder"]</option>
                            @foreach (var option in languages)
                            {
                                <option value="@option.Id">@GetDisplay(option)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => profile.LanguageId" class="text-error text-sm mt-1" />
                    </fieldset>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">@L["Profile_Intention"]</legend>
                        <InputSelect @bind-Value="profile.IntentionId" class="@SelectClass(() => profile.IntentionId)">
                            <option value="">@L["ProfileSetup_SelectPlaceholder"]</option>
                            @foreach (var option in intentions)
                            {
                                <option value="@option.Id">@GetDisplay(option)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => profile.IntentionId" class="text-error text-sm mt-1" />
                    </fieldset>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">@L["Profile_Ethnicity"]</legend>
                        <InputSelect @bind-Value="profile.EthnicityId" class="@SelectClass(() => profile.EthnicityId)">
                            <option value="">@L["ProfileSetup_SelectPlaceholder"]</option>
                            @foreach (var option in ethnicities)
                            {
                                <option value="@option.Id">@GetDisplay(option)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => profile.EthnicityId" class="text-error text-sm mt-1" />
                    </fieldset>

                    <button class="btn btn-primary rounded-full" type="submit">@L["ProfileSetup_SaveButton"]</button>
                </EditForm>
            }
        </section>
    </div>
</div>

@code {
    private UserProfileSetupForm profile = new();
    private EditContext editContext = default!;
    private IReadOnlyList<ProfileLookupOption> genders = [];
    private IReadOnlyList<ProfileLookupOption> sexualities = [];
    private IReadOnlyList<ProfileLookupOption> studyDomains = [];
    private IReadOnlyList<ProfileLookupOption> schools = [];
    private IReadOnlyList<ProfileLookupOption> languages = [];
    private IReadOnlyList<ProfileLookupOption> intentions = [];
    private IReadOnlyList<ProfileLookupOption> ethnicities = [];
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = true;

    protected override void OnInitialized()
    {
        InitEditContext();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private void InitEditContext()
    {
        if (editContext is not null)
            editContext.OnValidationStateChanged -= HandleValidationStateChanged;

        editContext = new EditContext(profile);
        editContext.OnValidationStateChanged += HandleValidationStateChanged;
    }

    private void HandleValidationStateChanged(object? sender, ValidationStateChangedEventArgs e)
        => StateHasChanged();

    private async Task LoadAsync()
    {
        errorMessage = null;
        successMessage = null;
        isLoading = true;

        try
        {
            var response = await ProfileClient.GetSetupAsync();
            profile = response.Profile;
            InitEditContext();
            genders = response.Genders;
            sexualities = response.Sexualities;
            studyDomains = response.StudyDomains;
            schools = response.Schools;
            languages = response.Languages;
            intentions = response.Intentions;
            ethnicities = response.Ethnicities;
        }
        catch (ApiClientException)
        {
            errorMessage = L["ProfileSetup_LoadError"];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        errorMessage = null;
        successMessage = null;

        var request = new UpdateUserProfileRequest
        {
            GenderId = profile.GenderId,
            SexualityId = profile.SexualityId,
            StudyDomainId = profile.StudyDomainId!.Value,
            SchoolId = profile.SchoolId!.Value,
            LanguageId = profile.LanguageId!.Value,
            IntentionId = profile.IntentionId!.Value,
            EthnicityId = profile.EthnicityId!.Value,
        };

        try
        {
            await ProfileClient.UpdateSetupAsync(request);
            successMessage = L["ProfileSetup_SaveSuccess"];
        }
        catch (ApiClientException)
        {
            errorMessage = L["ProfileSetup_SaveError"];
        }
    }

    private string SelectClass(Expression<Func<Guid?>> accessor)
    {
        var fi = FieldIdentifier.Create(accessor);
        var hasError = editContext.GetValidationMessages(fi).Any();
        return hasError
            ? "select select-bordered w-full select-error"
            : "select select-bordered w-full";
    }

    private string GetDisplay(ProfileLookupOption option)
    {
        if (string.IsNullOrWhiteSpace(option.DisplayKey))
            return option.Name;

        var localized = L[option.DisplayKey];
        return localized.ResourceNotFound ? option.Name : localized.Value;
    }

    private string GetValidationMessage(string key)
    {
        var localized = L[key];
        return localized.ResourceNotFound ? key : localized.Value;
    }

    public void Dispose()
    {
        if (editContext is not null)
            editContext.OnValidationStateChanged -= HandleValidationStateChanged;
    }
}
