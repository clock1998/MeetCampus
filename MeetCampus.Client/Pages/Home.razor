@page "/"

<PageTitle>Home</PageTitle>

<main class="relative">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-indigo-600 via-sky-500 to-cyan-400 text-white">
    <div class="max-w-7xl mx-auto px-6 py-24 lg:py-36">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight mb-6">Your Product Name</h1>
          <p class="text-lg sm:text-xl opacity-90 mb-8">[Placeholder — Short, persuasive tagline that explains the main value proposition in one sentence]</p>
          <div class="flex gap-4">
            <a class="inline-flex items-center justify-center px-6 py-3 bg-white text-indigo-700 font-semibold rounded-lg shadow hover:bg-gray-100" href="#">Get started</a>
            <a class="inline-flex items-center justify-center px-6 py-3 border border-white/30 text-white font-medium rounded-lg hover:bg-white/10" href="#">Learn more</a>
          </div>
        </div>

        <div class="rounded-2xl bg-white/10 p-6 backdrop-blur-sm">
          <div class="h-64 sm:h-80 bg-white/5 rounded-lg flex items-center justify-center text-white/80">
            <div class="text-center max-w-xs">
              <div class="h-24 w-24 rounded-full bg-white/10 mx-auto mb-4"></div>
              <p class="text-sm">[Placeholder — screenshot or device mockup goes here]</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- decorative SVG -->
    <div class="absolute inset-x-0 bottom-0 -mb-1 pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 1200 120" preserveAspectRatio="none" class="w-full h-20 text-white/20"><path d="M0,0 C150,100 350,0 600,50 C850,100 1050,0 1200,50 L1200,120 L0,120 Z" fill="currentColor"/></svg>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-6">Why choose us</h2>
      <p class="text-gray-600 mb-10">[Placeholder — a short paragraph describing a few benefits]</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 border rounded-xl hover:shadow-lg transition">
          <div class="h-12 w-12 rounded-md bg-indigo-50 text-indigo-600 flex items-center justify-center mb-4">A</div>
          <h3 class="font-semibold mb-2">Feature One</h3>
          <p class="text-sm text-gray-600">[Placeholder — short feature description]</p>
        </div>

        <div class="p-6 border rounded-xl hover:shadow-lg transition">
          <div class="h-12 w-12 rounded-md bg-indigo-50 text-indigo-600 flex items-center justify-center mb-4">B</div>
          <h3 class="font-semibold mb-2">Feature Two</h3>
          <p class="text-sm text-gray-600">[Placeholder — short feature description]</p>
        </div>

        <div class="p-6 border rounded-xl hover:shadow-lg transition">
          <div class="h-12 w-12 rounded-md bg-indigo-50 text-indigo-600 flex items-center justify-center mb-4">C</div>
          <h3 class="font-semibold mb-2">Feature Three</h3>
          <p class="text-sm text-gray-600">[Placeholder — short feature description]</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Callout -->
  <section class="bg-gray-50 py-12">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h3 class="text-2xl font-bold mb-4">Ready to try?</h3>
      <p class="text-gray-600 mb-6">[Placeholder — short call to action]</p>
      <a class="inline-block px-8 py-3 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700" href="#">Start free</a>
    </div>
  </section>
</main>
