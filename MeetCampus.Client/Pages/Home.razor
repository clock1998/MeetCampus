@page "/"
@using MeetCampus.Client.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Home_PageTitle"]</PageTitle>

<main class="bg-base-100 relative">
  <!-- Hero Section: The Hook -->
  <section class="bg-base-100 relative pt-12 pb-20 lg:pt-24 lg:pb-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <!-- Left: Headline & CTA -->
        <div class="space-y-8">
          <div class="space-y-4">
            <h1 class="text-base-content text-5xl leading-tight font-bold sm:text-6xl">
              @L["Home_HeroTitle"]
            </h1>
            <p class="text-base-content/70 text-xl leading-relaxed">
              @L["Home_HeroSubtitle"]
            </p>
          </div>

          <div class="flex flex-col gap-4 sm:flex-row">
            <a href="/register" class="btn btn-lg btn-primary rounded-full px-8">
              @L["Home_JoinButton"]
            </a>
            <a href="https://github.com/clock1998/MeetCampus" target="_blank" rel="noopener noreferrer" class="btn btn-lg btn-outline btn-neutral gap-2 rounded-full px-8">
              <span class="text-lg">→</span> @L["Home_GitHubButton"]
            </a>
          </div>

          <!-- Trust Badges -->
          <div class="flex flex-wrap gap-3 pt-4">
            <span class="badge badge-ghost gap-1 rounded-full">@L["Home_BadgePrivacy"]</span>
            <span class="badge badge-ghost gap-1 rounded-full">@L["Home_Badge100Free"]</span>
            <span class="badge badge-ghost gap-1 rounded-full">@L["Home_BadgeOpenSource"]</span>
          </div>
        </div>

        <!-- Right: Visual Hero -->
        <div class="hidden items-center justify-center lg:flex">
          <div class="card bg-base-200 w-full rounded-3xl p-8 shadow-sm">
            <figure class="from-base-300 to-base-200 text-base-content/40 mb-6 flex h-80 items-center justify-center rounded-2xl bg-gradient-to-br">
              <div class="text-center">
                <div class="bg-base-100 mx-auto mb-4 flex h-20 w-20 items-center justify-center rounded-full text-2xl">👥</div>
                <p class="text-sm font-medium">@L["Home_CommunityAwaits"]</p>
              </div>
            </figure>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The MeetCampus Manifesto -->
  <section class="bg-base-200/30 px-6 py-20">
    <div class="mx-auto max-w-4xl">
      <div class="card bg-base-100 border-base-300 rounded-3xl border p-8 shadow-sm lg:p-12">
        <div class="space-y-6">
          <h2 class="text-base-content text-4xl font-bold">
            @L["Home_ManifestoTitle"]
          </h2>
          <p class="text-base-content/70 text-lg leading-relaxed">
            @L["Home_ManifestoBody"]
          </p>
          <div class="divider my-4"></div>
          <p class="text-base-content/60 italic">
            @L["Home_ManifestoQuote"]
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Promise: Bento Box Style -->
  <section class="bg-base-100 px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12">
        <h2 class="text-base-content mb-4 text-4xl font-bold">@L["Home_PromiseTitle"]</h2>
        <p class="text-base-content/70 text-lg leading-relaxed">
          @L["Home_PromiseSubtitle"]
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-2">
        <div class="card bg-base-200 border-base-300 rounded-3xl border p-8 shadow-sm transition hover:shadow-md">
          <div class="mb-4 flex items-start gap-4">
            <div class="text-3xl">💚</div>
            <h3 class="text-base-content text-2xl font-bold">@L["Home_Promise1Title"]</h3>
          </div>
          <p class="text-base-content/70 leading-relaxed">@L["Home_Promise1Body"]</p>
        </div>

        <div class="card bg-base-200 border-base-300 rounded-3xl border p-8 shadow-sm transition hover:shadow-md">
          <div class="mb-4 flex items-start gap-4">
            <div class="text-3xl">⚖️</div>
            <h3 class="text-base-content text-2xl font-bold">@L["Home_Promise2Title"]</h3>
          </div>
          <p class="text-base-content/70 leading-relaxed">@L["Home_Promise2Body"]</p>
        </div>

        <div class="card bg-base-200 border-base-300 rounded-3xl border p-8 shadow-sm transition hover:shadow-md">
          <div class="mb-4 flex items-start gap-4">
            <div class="text-3xl">🤝</div>
            <h3 class="text-base-content text-2xl font-bold">@L["Home_Promise3Title"]</h3>
          </div>
          <p class="text-base-content/70 leading-relaxed">@L["Home_Promise3Body"]</p>
        </div>

        <div class="card bg-base-200 border-base-300 rounded-3xl border p-8 shadow-sm transition hover:shadow-md">
          <div class="mb-4 flex items-start gap-4">
            <div class="text-3xl">✓</div>
            <h3 class="text-base-content text-2xl font-bold">@L["Home_Promise4Title"]</h3>
          </div>
          <p class="text-base-content/70 leading-relaxed">@L["Home_Promise4Body"]</p>
        </div>

        <div class="card bg-base-200 border-base-300 rounded-3xl border p-8 shadow-sm transition hover:shadow-md md:col-span-2 lg:col-span-1">
          <div class="mb-4 flex items-start gap-4">
            <div class="text-3xl">🎭</div>
            <h3 class="text-base-content text-2xl font-bold">@L["Home_Promise5Title"]</h3>
          </div>
          <p class="text-base-content/70 leading-relaxed">@L["Home_Promise5Body"]</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works: Minimalist List -->
  <section class="bg-base-200/20 px-6 py-20">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-base-content mb-12 text-4xl font-bold">@L["Home_HowTitle"]</h2>

      <div class="space-y-8">
        <div class="flex items-start gap-6">
          <div class="flex-shrink-0">
            <div class="bg-base-300 text-base-content flex h-12 w-12 items-center justify-center rounded-full font-bold">1</div>
          </div>
          <div>
            <h3 class="text-base-content mb-2 text-xl font-semibold">@L["Home_Step1Title"]</h3>
            <p class="text-base-content/70 leading-relaxed">@L["Home_Step1Body"]</p>
          </div>
        </div>

        <div class="flex items-start gap-6">
          <div class="flex-shrink-0">
            <div class="bg-base-300 text-base-content flex h-12 w-12 items-center justify-center rounded-full font-bold">2</div>
          </div>
          <div>
            <h3 class="text-base-content mb-2 text-xl font-semibold">@L["Home_Step2Title"]</h3>
            <p class="text-base-content/70 leading-relaxed">@L["Home_Step2Body"]</p>
          </div>
        </div>

        <div class="flex items-start gap-6">
          <div class="flex-shrink-0">
            <div class="bg-base-300 text-base-content flex h-12 w-12 items-center justify-center rounded-full font-bold">3</div>
          </div>
          <div>
            <h3 class="text-base-content mb-2 text-xl font-semibold">@L["Home_Step3Title"]</h3>
            <p class="text-base-content/70 leading-relaxed">@L["Home_Step3Body"]</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Footer: Icons & Text -->
  <section class="bg-base-100 border-base-300 border-t px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <div class="flex flex-col items-center text-center">
          <div class="mb-4 text-5xl">🛡️</div>
          <h3 class="text-base-content mb-2 text-lg font-semibold">@L["Home_Trust1Title"]</h3>
          <p class="text-base-content/70">@L["Home_Trust1Body"]</p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="mb-4 text-5xl">🔐</div>
          <h3 class="text-base-content mb-2 text-lg font-semibold">@L["Home_Trust2Title"]</h3>
          <p class="text-base-content/70">@L["Home_Trust2Body"]</p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="mb-4 text-5xl">💻</div>
          <h3 class="text-base-content mb-2 text-lg font-semibold">@L["Home_Trust3Title"]</h3>
          <p class="text-base-content/70">@L["Home_Trust3Body"]</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-base-200/40 px-6 py-20">
    <div class="mx-auto max-w-4xl space-y-8 text-center">
      <div>
        <h2 class="text-base-content mb-4 text-4xl font-bold">@L["Home_CtaTitle"]</h2>
        <p class="text-base-content/70 text-lg leading-relaxed">
          @L["Home_CtaSubtitle"]
        </p>
      </div>

      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <a href="/register" class="btn btn-lg btn-primary rounded-full px-8">
          @L["Home_CtaGetStarted"]
        </a>
        <a href="/about" class="btn btn-lg btn-ghost btn-outline rounded-full px-8">
          @L["Home_CtaLearnMore"]
        </a>
      </div>
    </div>
  </section>
</main>
